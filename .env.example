# Copie este arquivo para .env.local e ajuste os valores conforme necessário.
# Nenhuma dessas variáveis é secreta: são identificadores públicos que o
# Google já expõe no HTML/JS enviado ao navegador em qualquer site.

# URL canônica do site, usada em metadata, sitemap.xml e robots.txt.
NEXT_PUBLIC_SITE_URL=https://geek.arstechcompany.com.br

# Prefixo de caminho quando o site é servido em subpasta (GitHub Pages sem
# domínio customizado, ex.: usuario.github.io/arstechcompany-geek).
# Deixe vazio quando servido na raiz (domínio customizado). No deploy via
# GitHub Actions este valor é detectado automaticamente — não precisa definir.
NEXT_PUBLIC_BASE_PATH=

# ID de métricas do Google Analytics (gtag). Deixe em branco para desativar.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-84NNFCLZVT

# Client ID do Google AdSense. Deixe em branco para desativar.
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-9829402470557693
